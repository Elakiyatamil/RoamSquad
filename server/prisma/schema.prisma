generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Country {
  id        String   @id @default(uuid())
  name      String   @unique
  flag      String?
  code      String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  states    State[]
}

model State {
  id        String     @id @default(uuid())
  name      String
  countryId String
  active    Boolean    @default(true)
  districts District[]
  country   Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)

  @@unique([name, countryId])
}

model District {
  id             String          @id @default(uuid())
  name           String
  stateId        String
  active         Boolean         @default(true)
  destinations   Destination[]
  state          State           @relation(fields: [stateId], references: [id], onDelete: Cascade)
  mustVisitSpots MustVisitSpot[]
  upcomingEvents UpcomingEvent[]

  @@unique([name, stateId])
}

model Destination {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  districtId    String
  description   String?
  category      String
  rating        Float           @default(4.0)
  coverImage    String?
  images        String[]
  avgCost       String?
  bestSeason    String?
  active        Boolean         @default(true)
  status        String          @default("DRAFT")
  createdAt     DateTime        @default(now())

  activities    Activity[]
  foodOptions   FoodOption[]
  accommodations Accommodation[]
  district      District        @relation(fields: [districtId], references: [id], onDelete: Cascade)
  travelOptions TravelOption[]
}


model Activity {
  id            String   @id @default(cuid())
  name          String
  duration      String
  price         Float
  description   String
  icon          String?
  images        String[]
  imageUrl      String?
  isFeatured    Boolean     @default(false)
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)

  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}


model FoodOption {
  id            String   @id @default(cuid())
  name          String
  type          String
  price         Float
  icon          String?
  description   String
  mealType      String?

  dietaryTags   String[]
  imageUrl      String?
  isFeatured    Boolean     @default(false)
  isActive      Boolean     @default(true)
  sortOrder     Int         @default(0)

  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}


model Accommodation {
  id                String   @id @default(cuid())
  tier              String
  price             Float
  hotelNameInternal String?
  description       String
  stars             Int?
  includes          String[]
  imageUrl          String?
  isFeatured        Boolean     @default(false)
  isActive          Boolean     @default(true)


  destinationId String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}


model TravelOption {
  id            String      @id @default(uuid())
  destinationId String
  mode          String
  icon          String?
  description   String?
  cost          Float
  duration      String
  destination   Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
}


model MustVisitSpot {
  id          String   @id @default(uuid())
  districtId  String
  name        String
  description String?
  icon        String?
  isLocked    Boolean  @default(true)
  district    District @relation(fields: [districtId], references: [id], onDelete: Cascade)
}

model UpcomingEvent {
  id             String   @id @default(uuid())
  districtId     String?
  title          String
  name           String?
  description    String?
  dateTime       DateTime?
  startDate      DateTime?
  endDate        DateTime?
  bannerImage    String?
  image          String?
  location       String?
  contactNumber  String?
  isFeatured     Boolean  @default(false)
  createdAt      DateTime @default(now())
  district       District? @relation(fields: [districtId], references: [id], onDelete: Cascade)
  interests      EventInterest[]
}

model Package {
  id         String   @id @default(uuid())
  name       String
  daysCount  Int
  totalPrice Int
  highlights String[]
  tag        String?
  coverImage String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  interests  PackageInterest[]
}

model ItineraryRequest {
  id          String    @id @default(uuid())
  userId      String?   // Optional for registered users
  userName    String
  userEmail   String
  userPhone   String?
  destination String
  travelDates String
  budget      String
  travelers   Int
  travelType  String?   // Couple, Family, Solo, etc.
  vibe        String?   // Relaxation, Nature, etc.
  activities  String[]
  timeline    Json?
  status        String    @default("new")
  agentNotes    String?
  quoteAmount   Float?
  quoteDetails  String?
  createdAt     DateTime  @default(now())
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model TripPlan {
  id              String   @id @default(uuid())
  userId          String?
  days            Int
  travellers      Int
  vibe            String?
  activities      Json?
  timeline        Json?
  estimatedBudget Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WishlistItem {
  id            String   @id @default(uuid())
  userId        String
  entityType    String   // Destination, Activity
  entityId      String
  createdAt     DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, entityType, entityId])
}


model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String?
  role      String   @default("USER")
  createdAt DateTime @default(now())
  logs      AuditLog[]
  requests  ItineraryRequest[]
  tripPlans TripPlan[]
  wishlist  WishlistItem[]
}

model AuditLog {
  id          String   @id @default(uuid())
  userId      String
  userName    String?
  action      String   // CREATE, UPDATE, DELETE
  entity      String   // Country, State, District, Destination, etc.
  entityId    String?
  entityName  String?
  details     String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Inquiry {
  id          Int      @id @default(autoincrement())
  userId      String?
  name        String
  email       String
  phone       String
  destinationId String?
  destinationName String?
  state       String?
  district    String?
  itinerary   Json?
  hotel       String?
  food        String?
  itinerarySnapshot Json?
  hotelSnapshot     Json?
  foodSnapshot      Json?
  days        Int?
  people      Int?
  totalBudget Int?
  startDate   DateTime?
  tripDate    DateTime?
  status      String   @default("INQUIRY SENT")
  createdAt   DateTime @default(now())
}

model WishlistLead {
  id          String   @id @default(uuid())
  email       String
  destination String
  itinerary   Json?
  totalBudget Float?
  createdAt   DateTime @default(now())
}

model PackageInterest {
  id         String   @id @default(uuid())
  packageId  String
  package    Package  @relation(fields: [packageId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  phone      String?
  createdAt  DateTime @default(now())
}

model EventInterest {
  id         String   @id @default(uuid())
  eventId    String
  event      UpcomingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  email      String
  name       String?
  phone      String?
  createdAt  DateTime @default(now())
}
